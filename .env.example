# ── OpenRouter ──────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
EMBEDDING_MODEL=qwen/qwen3-embedding-8b
LLM_MODEL=deepseek/deepseek-v3.2

# ── Jina ────────────────────────────────────────────────
JINA_API_KEY=jina_xxxxxxxxxxxxxxxxxxxx

# ── Qdrant ──────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
COLLECTION_NAME=admin_docs

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Retrieval tuning ────────────────────────────────────
# Set to false to keep chunks with negative reranker scores
FILTER_NEGATIVE_SCORES=false
# Number of candidates each hybrid search arm returns before RRF fusion
HYBRID_PREFETCH_LIMIT=15

# ── App ─────────────────────────────────────────────────
LOG_LEVEL=INFO
APP_ENV=development
# Comma-separated allowed origins. In local dev, leave empty to use localhost defaults.
CORS_ALLOW_ORIGINS=

# In non-local environments, /ingest requires this header token (X-Ingest-Token).
INGEST_API_KEY=

# ── Route abuse protection ──────────────────────────────
RATE_LIMIT_WINDOW_SECONDS=60
AUTH_LOGIN_RATE_LIMIT=8
CHAT_RATE_LIMIT=40
INGEST_RATE_LIMIT=6
